# ─── PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_postgres_password
DB_NAME=school_attendance

# ─── Pipeline ─────────────────────────────────────────────────
MODE=heavy
SIMILARITY_THRESHOLD=0.40
REQUIRED_UPLOAD=15
REQUIRED_VALID=7

# ONNX Runtime execution providers, priority order (first available wins).
#   CPU only (default):  CPUExecutionProvider
#   NVIDIA GPU:          CUDAExecutionProvider,CPUExecutionProvider
#   Windows DirectML:    DmlExecutionProvider,CPUExecutionProvider
ONNX_PROVIDERS=CPUExecutionProvider

# Directory holding the .onnx models (buffalo_sc/ and buffalo_l/ subfolders).
MODEL_DIR=~/.insightface/models

# ─── Security ─────────────────────────────────────────────────
# Set to require an X-API-Key header on the processing/registration endpoints.
# Leave empty to keep the endpoints open (backward-compatible default).
API_KEY=
# Comma-separated allowed CORS origins. Empty = no cross-origin browser access.
ALLOWED_ORIGINS=https://your-lms.example.com
# Maximum accepted size (bytes) per uploaded image. Default 10 MB.
MAX_UPLOAD_BYTES=10485760

# ─── LMS integration ──────────────────────────────────────────
LMS_API_URL=https://your-lms.example.com/api/attendance
